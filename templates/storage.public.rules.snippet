// Public / production Cloud Storage rules.
// Production users should NOT need allowedEnvs.
// Use a dedicated production bucket (e.g. myapp-prod).

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
