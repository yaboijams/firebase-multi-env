{
  "name": "firebase-multi-env",
  "version": "0.0.0-development",
  "description": "Multi-environment Firebase routing (Origin + allowedEnvs claims) with optional pinned per-env deploys",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "firebase-multi-env": "bin/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./functions-v1": {
      "types": "./dist/functions-v1.d.ts",
      "import": "./dist/functions-v1.js",
      "require": "./dist/functions-v1.cjs"
    },
    "./functions-v2": {
      "types": "./dist/functions-v2.d.ts",
      "import": "./dist/functions-v2.js",
      "require": "./dist/functions-v2.cjs"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js",
      "require": "./dist/http.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "semantic-release": "semantic-release"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "peerDependencies": {
    "firebase": ">=10",
    "firebase-admin": ">=11",
    "firebase-functions": ">=4"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "firebase-functions": {
      "optional": true
    }
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "semantic-release": "^25.0.6",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "firebase",
    "firestore",
    "multi-environment",
    "qa",
    "staging",
    "cloud-functions"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaboijams/firebase-multi-env.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
